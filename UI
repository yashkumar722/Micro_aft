async function callClaude(data) {
  const prompts = {
    manual: `You are Zerot AI, a smart financial assistant for Indian MSMEs. A business owner just recorded: Category: ${data.type}, Amount: ₹${data.amount}, Description: "${data.description}", Party: "${data.party}", Date: ${data.date}. In 2-3 sentences, give a specific, actionable insight about this transaction — mention cash flow, seasonality, or cost patterns if relevant. Be direct and practical, like a trusted CA.`,
    whatsapp: `You are Zerot AI. A business owner shared this WhatsApp chat export: "${data.raw?.slice(0, 800)}". Extract 2-3 key business transactions mentioned and summarize the financial activity in 2-3 sentences. Mention any notable amounts, parties, or patterns you spotted.`,
    excel: `You are Zerot AI. A business uploaded an Excel/CSV file named "${data.file}" (${(data.size / 1024).toFixed(1)} KB). In 2-3 sentences, tell them what to expect from the data import process, what columns Zerot will auto-map, and what insights they'll get after processing.`,
    tally: `You are Zerot AI. A business uploaded a Tally XML export named "${data.file}". In 2-3 sentences, describe how Zerot will process this — ledger entries, voucher types, and what financial insights will be generated from the Tally data.`,
    bank: `You are Zerot AI. A business uploaded a ${data.bank} bank statement PDF. In 2-3 sentences, explain how Zerot's AI will parse and auto-categorize the transactions, what patterns it might find, and what cash flow insight the owner can expect.`,
  };

  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      messages: [{ role: "user", content: prompts[data.source] || prompts.manual }],
    }),
  });
  const json = await response.json();
  return json.content?.[0]?.text || "Insight unavailable.";
}

