          background: "#0a2a18", border: "1px solid #00ff87",
          borderRadius: 20, padding: "10px 20px",
          color: "#00ff87", fontFamily: "'DM Mono', monospace", fontSize: 12,
          animation: "fadeUp 0.3s ease", zIndex: 999,
          boxShadow: "0 0 30px rgba(0,255,135,0.15)",
        }}>
          {toast}
        </div>
      )}
    </div>
  );
}
